{
  "name": "@agentkarma/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentKarma — the reputation layer for autonomous on-chain agents.",
  "license": "MIT",
  "author": "Kerem Noras <kerem@noras.tech>",
  "homepage": "https://agentkarma.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentkarmaio/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/agentkarmaio/sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agentkarma",
    "reputation",
    "agents",
    "trust",
    "erc-8004",
    "x402",
    "solana",
    "celo",
    "preflight"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.2"
  }
}

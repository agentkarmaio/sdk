{
  "name": "@agentkarma/sdk",
  "version": "0.2.2",
  "description": "TypeScript SDK for AgentKarma — the reputation layer for autonomous on-chain agents.",
  "license": "MIT",
  "author": "Kerem Noras <kerem@noras.tech>",
  "homepage": "https://agentkarma.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentkarmaio/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/agentkarmaio/sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js",
      "default": "./dist/tools.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "default": "./dist/mcp.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agentkarma-mcp": "./dist/mcp-cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/mcp-cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentkarma",
    "reputation",
    "agents",
    "trust",
    "erc-8004",
    "x402",
    "solana",
    "celo",
    "preflight",
    "mcp",
    "model-context-protocol"
  ],
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0 <2"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.2"
  }
}
